<style>


.column__item-imgwrap img {

    aspect-ratio: 0.75; /* statt 0.25 für ein natürlicheres Verhältnis */

}

.img {
    border-radius: 1em;
    width: 100%;
    height: auto;
    aspect-ratio: 0.25;
    object-fit: cover;
}

.column__item {
    margin-bottom: 5rem;
}



/* Show warning for older browsers */


.sad {

  overflow-y: auto;
    -webkit-mask-image: linear-gradient(to bottom, transparent, #262626 10%);
  mask-image: linear-gradient(to bottom, transparent, #262626 10%);

  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
    -ms-overflow-style: none;  /* Internet Explorer 10+ */
    scrollbar-width: none;  /* Firefox */
}
.sad::-webkit-scrollbar { 
    display: none;  /* Safari and Chrome */
}
</style>

<script>
  import GLightbox from 'glightbox'

  const lightbox = GLightbox({
        touchNavigation: true,
    loop: true,
    autoplayVideos: true
  })

const container = document.querySelector('.sad');
const timeline = new ScrollTimeline({
  source: container,
  timeRange: 1,
  fill: 'both'
});

function setupAnimations() {
  const items = Array.from(container.querySelectorAll('.column__item'));

  // Vorher alles im Container löschen (alte Spaltenstruktur)
  container.innerHTML = '';

  const isMobile = window.innerWidth <= 640;
  const columnCount = isMobile ? 2 : 3;

  // Neuen Wrapper für Spalten bauen
  const columnsContainer = document.createElement('div');
  columnsContainer.className = isMobile
    ? 'columns-2 gap-4 overflow-y-hidden'
    : 'columns-3 gap-8 overflow-y-hidden sm:columns-3 sm:gap-8';
  columnsContainer.setAttribute('data-scroll-container', '');

  container.appendChild(columnsContainer);

  // Columns erzeugen und stylen
  const columns = [];
  for (let i = 0; i < columnCount; i++) {
    const col = document.createElement('div');
    col.classList.add('column');
    col.style.display = 'flex';
    col.style.flexDirection = 'column';
    col.style.padding = '10vh 0';
    col.style.margin = '2vh';
    columns.push(col);
    columnsContainer.appendChild(col);
  }

  // Items gleichmäßig verteilen
  items.forEach((item, index) => {
    const targetCol = columns[index % columnCount];
    targetCol.appendChild(item);
  });

  // Scroll-Animationen
  columns.forEach((col, index) => {
    
    if (isMobile) {
const isReversed = index === 1 ;
      col.style.flexDirection = isReversed ? 'column-reverse' : 'column';

      const animation = isReversed
        ? [
            { transform: 'translateY(calc(-100% + 70vh))' },
            { transform: 'translateY(calc(100% - 70vh))' }
          ]
        : [
            { transform: 'translateY(0)' },
            { transform: 'translateY(0)' }
          ];

      col.animate(animation, { duration: 1, fill: 'both', timeline });
    } else {
      const isReversed = index === 0 || index === 2;
      col.style.flexDirection = isReversed ? 'column-reverse' : 'column';

      const animation = isReversed
        ? [
            { transform: 'translateY(calc(-100% + 100vh))' },
            { transform: 'translateY(calc(100% - 100vh))' }
          ]
        : [
            { transform: 'translateY(0)' },
            { transform: 'translateY(0)' }
          ];

      col.animate(animation, { duration: 1, fill: 'both', timeline });
    }
  });
}

// Initial aufrufen
setupAnimations();
let lastWidth = window.innerWidth;

window.addEventListener('resize', () => {
  if (window.innerWidth !== lastWidth) {
    lastWidth = window.innerWidth;
    setupAnimations();
  }
});
</script>


