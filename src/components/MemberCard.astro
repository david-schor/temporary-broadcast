---
export interface Props {
  imgSrc: string;
  name: string;
  description: string;
  username: string;
}

import { Image } from 'astro:assets';

const { imgSrc, name, description, username } = Astro.props;
---

<div class="carousel-item h-full flex flex-col sm:flex-row justify-center items-center sm:items-center relative">
  <div class="w-full sm:w-1/2 h-full relative">
    <Image width="800" height="1000" quality=100 src={imgSrc} alt={name} class="object-cover w-full h-full" />
  </div>
  <div class="w-full sm:w-1/2 h-fit sm:h-full absolute bottom-0 left-0 flex flex-col justify-end items-start text-left sm:static sm:flex sm:justify-center sm:items-center sm:text-center z-10 sm:bg-neutral">
    <div style="background-image: linear-gradient(to top, #262626 40%, transparent);" class="w-full p-4 sm:px-20 sm:max-w-prose sm:p-0 text-white">
      <h2 class="font-black text-2xl sm:text-3xl md:text-4xl mb-2">{name}</h2>
      <p class="text-base sm:text-md md:text-xl">{description}</p>
      <div class="flex justify-center">
<a href={`https://instagram.com/${username}`} aria-label="Instagram">
    <svg class="w-7 h-7 md:w-10 md:h-10 fill-white md:mt-10" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
