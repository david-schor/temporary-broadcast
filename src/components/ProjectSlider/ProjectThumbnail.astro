---
const { image, title } = Astro.props;

import { Image } from 'astro:assets';
---

<div class="item active snap-center relative flex-shrink-0 w-[150px] h-[220px] transition duration-500">
        <Image
          src={image}
          alt="image"
          height="800"
          width="800"
          class="skeleton w-full h-full background absolute inset-0 w-full h-full object-cover rounded-lg filter brightness-50 transition-filter"
        />
        <div class="text-mask absolute inset-0 flex items-center justify-center rounded-lg overflow-hidden">
      <svg viewBox="0 0 300 150" preserveAspectRatio="xMidYMid slice" class="w-full h-full">
        <defs>
          <mask id={`mask-${title}`}>   
            <rect width="100%" height="100%" fill="black"/>
            <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle"
                  class="font-black" fill="white">{title.toUpperCase()}</text>
          </mask>
        </defs>
        <image href={image.src} width="100%" height="100%" preserveAspectRatio="xMidYMid slice" mask={`url(#mask-${title})`} />
      </svg>
    </div>
 
    <style>
.thumbnail {
  -ms-overflow-style: none; /* IE/Edge */
  scrollbar-width: none; /* Firefox */
  overflow-y: hidden;     /* verhindert vertikales Scrollen */
}

.thumbnail::-webkit-scrollbar {
  display: none; /* Chrome/Safari */
}

/* Thumbnail Items */
.thumbnail .item {
  flex-shrink: 0;
  width: 150px;
  height: 220px;
  position: relative;
  transition: filter 0.5s;
  scroll-snap-align: center;
}

/* Hintergrundbilder der Thumbnails */
.thumbnail .item img.background {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 0.5rem;
  filter: brightness(0.5);
  transition: filter 0.5s;
}

/* Aktives Thumbnail */
.thumbnail .item.active img.background {
  filter: brightness(1) !important;
}

/* Textmasken */
.thumbnail .item .text-mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0.5rem;
  overflow: hidden;
}

/* Aktive Textmasken ausblenden */
.thumbnail .item.active .text-mask {
  display: none !important;
}
    </style>

    